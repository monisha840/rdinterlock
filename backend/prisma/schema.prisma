generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Machine {
  id          String       @id @default(uuid())
  name        String       @unique
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  productions Production[]

  @@map("machines")
}

model BrickType {
  id                 String                   @id @default(uuid())
  size               String                   @unique
  stock              Int                      @default(0)
  isActive           Boolean                  @default(true)
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  orderBrickTypes    ClientOrder[]            @relation("OrderBrickType")
  scheduleBrickTypes DispatchSchedule[]       @relation("ScheduleBrickType")
  dispatches         Dispatch[]
  productions        Production[]
  materialConfig     MaterialConfig?
  returns            BrickReturn[]

  @@map("brick_types")
}

model Worker {
  id                 String              @id @default(uuid())
  name               String
  role               String
  employeeType       String              @default("Worker") // Staff or Worker
  paymentType        String
  rate               Float               @default(0) // Legacy field (optional, keeping for compatibility)
  monthlySalary      Float               @default(0)
  weeklyWage         Float               @default(0)
  perBrickRate       Float               @default(0)
  isActive           Boolean             @default(true)
  advanceBalance     Float               @default(0)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  attendance         Attendance[]
  wages              DailyWage[]
  dispatchSchedules  DispatchSchedule[]
  expenses           Expense[]
  monthlySettlements MonthlySettlement[]
  productionWorkers  ProductionWorker[]
  settlements        WeeklySettlement[]
  advances           WorkerAdvance[]
  cashEntries        CashEntry[]
  dispatches         Dispatch[]          @relation("DriverDispatches")
  clientOrders       ClientOrder[]       @relation("OrderDriver")
  handledOrders      ClientOrder[]       @relation("OrderHandler")
  handledDispatches  Dispatch[]          @relation("DispatchHandler")
  transportEntries   TransportEntry[]    @relation("DriverTransport")
  staffPayments      StaffPayment[]

  @@map("workers")
}

model Production {
  id              String                   @id @default(uuid())
  date            DateTime
  machineId       String
  shift           String
  brickTypeId     String
  quantity        Int
  damagedBricks   Int                      @default(0)
  availableBricks Int                      @default(0)
  notes           String?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  workers         ProductionWorker[]       @relation("ProductionToWorkers")
  brickType       BrickType                @relation(fields: [brickTypeId], references: [id])
  machine         Machine                  @relation(fields: [machineId], references: [id])
  consumptionLogs MaterialConsumptionLog[]

  @@map("productions")
}

model ProductionWorker {
  id           String     @id @default(uuid())
  productionId String
  workerId     String
  quantity     Int
  createdAt    DateTime   @default(now())
  production   Production @relation("ProductionToWorkers", fields: [productionId], references: [id])
  worker       Worker     @relation(fields: [workerId], references: [id])

  @@map("production_workers")
}

model Customer {
  id                String             @id @default(uuid())
  name              String
  phone             String?
  address           String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  isActive          Boolean            @default(true)
  notes             String?
  orders            ClientOrder[]
  payments          ClientPayment[]
  dispatchSchedules DispatchSchedule[]
  dispatches        Dispatch[]
  cashEntries       CashEntry[]
  brickReturns      BrickReturn[]

  @@map("customers")
}

model ClientOrder {
  id                   String          @id @default(uuid())
  clientId             String
  brickTypeId          String
  quantity             Int
  rate                 Float           @default(0)
  totalAmount          Float           @default(0)
  orderDate            DateTime
  expectedDispatchDate DateTime?
  status               String          @default("PENDING")
  notes                String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  brickType            BrickType       @relation("OrderBrickType", fields: [brickTypeId], references: [id])
  client               Customer        @relation(fields: [clientId], references: [id])
  driverId             String?
  driver               Worker?         @relation("OrderDriver", fields: [driverId], references: [id])
  handledById          String?
  handledBy            Worker?         @relation("OrderHandler", fields: [handledById], references: [id])
  payments             ClientPayment[]
  dispatches         Dispatch[]
  dispatchSchedules  DispatchSchedule[]

  @@map("client_orders")
}

model ClientPayment {
  id            String       @id @default(uuid())
  clientId      String
  orderId       String?
  type          String       @default("PAYMENT")
  amount        Float
  paymentDate   DateTime
  paymentMethod String
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  client        Customer     @relation(fields: [clientId], references: [id])
  order         ClientOrder? @relation(fields: [orderId], references: [id])

  @@map("client_payments")
}

model DispatchSchedule {
  id           String    @id @default(uuid())
  clientId     String
  brickTypeId  String
  quantity     Int
  location     String?
  dispatchDate DateTime
  driverId     String?
  status       String    @default("SCHEDULED")
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  brickType    BrickType @relation("ScheduleBrickType", fields: [brickTypeId], references: [id])
  client       Customer  @relation(fields: [clientId], references: [id])
  driver       Worker?   @relation(fields: [driverId], references: [id])
  orderId      String?
  order        ClientOrder? @relation(fields: [orderId], references: [id])

  @@map("dispatch_schedules")
}

model Dispatch {
  id            String       @id @default(uuid())
  date          DateTime
  customerId    String
  brickTypeId   String
  quantity      Int
  distanceKm    Float?
  vehicleType   String
  transportCost Float        @default(0)
  loadingCost   Float        @default(0)
  paymentStatus String
  totalAmount   Float        @default(0)
  paidAmount    Float        @default(0)
  status        String       @default("Completed")
  location      String?
  driverId      String?
  vehicleNumber String?
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  brickType     BrickType    @relation(fields: [brickTypeId], references: [id])
  customer      Customer     @relation(fields: [customerId], references: [id])
  driver        Worker?      @relation("DriverDispatches", fields: [driverId], references: [id])
  handledById   String?
  handledBy     Worker?      @relation("DispatchHandler", fields: [handledById], references: [id])
  orderId       String?
  order         ClientOrder? @relation(fields: [orderId], references: [id])
  returns       BrickReturn[]

  @@map("dispatches")
}

model MaterialConfig {
  id             String    @id @default(uuid())
  brickTypeId    String    @unique
  cementPer1000  Float     @default(0)
  flyAshPer1000  Float     @default(0)
  powderPer1000  Float     @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  brickType      BrickType @relation(fields: [brickTypeId], references: [id])

  @@map("material_configs")
}

model MaterialConsumptionLog {
  id           String     @id @default(uuid())
  productionId String
  materialType String     // cement | flyash | powder
  quantityUsed Float
  date         DateTime
  createdAt    DateTime   @default(now())
  production   Production @relation(fields: [productionId], references: [id], onDelete: Cascade)

  @@map("material_consumption_logs")
}

model BrickReturn {
  id               String    @id @default(uuid())
  dispatchId       String
  clientId         String
  brickTypeId      String
  returnedQuantity Int
  reason           String?
  date             DateTime
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  dispatch         Dispatch  @relation(fields: [dispatchId], references: [id])
  client           Customer  @relation(fields: [clientId], references: [id])
  brickType        BrickType @relation(fields: [brickTypeId], references: [id])

  @@map("brick_returns")
}

model Expense {
  id          String          @id @default(uuid())
  date        DateTime
  category    String
  amount      Float
  notes       String?
  paymentMode String
  workerId    String?
  materialId  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  material    RawMaterial?    @relation(fields: [materialId], references: [id])
  worker      Worker?         @relation(fields: [workerId], references: [id])
  materials   MaterialUsage[]

  @@map("expenses")
}

model CashEntry {
  id          String   @id @default(uuid())
  date        DateTime
  type        String
  amount      Float
  description String
  category    String
  paymentMode String   @default("CASH")
  vendorName  String?
  customerId  String?
  workerId    String?
  materialId  String?
  isRecordOnly Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  customer    Customer? @relation(fields: [customerId], references: [id])
  worker      Worker?   @relation(fields: [workerId], references: [id])
  material    RawMaterial? @relation(fields: [materialId], references: [id])

  @@map("cash_entries")
}

model RawMaterial {
  id          String          @id @default(uuid())
  name        String          @unique
  unit        String
  description String?
  stock       Float           @default(0)
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  expenses    Expense[]
  cashEntries CashEntry[]
  usages      MaterialUsage[]

  @@map("raw_materials")
}

model MaterialUsage {
  id           String      @id @default(uuid())
  materialId   String
  quantity     Float
  pricePerUnit Float       @default(0)
  totalCost    Float       @default(0)
  date         DateTime
  expenseId    String?
  createdAt    DateTime    @default(now())
  expense      Expense?    @relation(fields: [expenseId], references: [id])
  material     RawMaterial @relation(fields: [materialId], references: [id])

  @@map("material_usages")
}

model Attendance {
  id       String   @id @default(uuid())
  workerId String
  date     DateTime
  present  Boolean  @default(true)
  worker   Worker   @relation(fields: [workerId], references: [id])

  @@unique([workerId, date])
  @@map("attendance")
}

model WorkerAdvance {
  id       String   @id @default(uuid())
  workerId String
  amount   Float
  type     String
  date     DateTime
  paymentMode String @default("CASH")
  note     String?
  worker   Worker   @relation(fields: [workerId], references: [id])

  @@map("worker_advances")
}

model DailyWage {
  id          String   @id @default(uuid())
  workerId    String
  date        DateTime
  bricksMade  Int?
  wageAmount  Float
  advanceUsed Float    @default(0)
  netPayable  Float
  isPaid      Boolean  @default(false)
  createdAt   DateTime @default(now())
  worker      Worker   @relation(fields: [workerId], references: [id])

  @@map("daily_wages")
}

model WeeklySettlement {
  id            String   @id @default(uuid())
  workerId      String
  startDate     DateTime
  endDate       DateTime
  totalAmount   Float
  paymentStatus String
  generatedAt   DateTime @default(now())
  notes         String?
  worker        Worker   @relation(fields: [workerId], references: [id])

  @@map("weekly_settlements")
}

model MonthlySettlement {
  id          String    @id @default(uuid())
  workerId    String
  month       Int
  year        Int
  salary      Float
  advanceUsed Float     @default(0)
  netPaid     Float
  isPaid      Boolean   @default(false)
  paidAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  worker      Worker    @relation(fields: [workerId], references: [id])

  @@unique([workerId, month, year])
  @@map("monthly_settlements")
}

model SystemSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

model TransportVehicle {
  id            String           @id @default(uuid())
  vehicleNumber String           @unique
  vehicleType   String           // COMPANY or VENDOR
  ownerName     String
  driverName    String?
  status        String           @default("ACTIVE") // ACTIVE or INACTIVE
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  entries       TransportEntry[]

  @@map("transport_vehicles")
}

model TransportVendor {
  id            String           @id @default(uuid())
  name          String           @unique
  phone         String?
  address       String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  entries       TransportEntry[]

  @@map("transport_vendors")
}

model TransportEntry {
  id                String           @id @default(uuid())
  date              DateTime
  transportType     String           // RD_VEHICLE or VENDOR_VEHICLE
  vehicleId         String
  vendorId          String?
  driverName        String?          // For RD vehicles, if different from vehicle's default driver
  loads             Int
  transactionType   String           // EXPENSE or INCOME
  expenseAmount     Float            @default(0)
  dieselCost        Float            @default(0) // Specific for RD vehicle
  otherExpense      Float            @default(0) // Specific for RD vehicle
  rentPerLoad       Float            @default(0) // Specific for Vendor vehicle
  incomeAmount      Float            @default(0) // Auto-calculated: loads * rentPerLoad
  notes             String?
  material          String?
  dispatchId        String?          // Linked to specific dispatch if auto-generated
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  
  vehicle           TransportVehicle @relation(fields: [vehicleId], references: [id])
  vendor            TransportVendor? @relation(fields: [vendorId], references: [id])
  driverId          String?
  driver            Worker?          @relation("DriverTransport", fields: [driverId], references: [id])

  @@map("transport_entries")
}

model Alert {
  id          String   @id @default(uuid())
  type        String   // stock / material / payment / salary
  message     String
  severity    String   // low / medium / high
  referenceId String?  // Optional: client_id / worker_id
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@map("alerts")
}

model Reminder {
  id          String   @id @default(uuid())
  title       String
  description String?
  dueDate     DateTime
  status      String   @default("PENDING") // PENDING / COMPLETED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("reminders")
}

model StaffPayment {
  id           String   @id @default(uuid())
  personId     String
  role         String
  amount       Float
  paymentType  String
  method       String
  date         DateTime
  note         String?
  createdAt    DateTime @default(now())
  
  worker       Worker   @relation(fields: [personId], references: [id])

  @@map("staff_payments")
}
