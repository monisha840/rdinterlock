// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Machine {
  id          String       @id @default(uuid())
  name        String       @unique
  productions Production[]
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("machines")
}

model BrickType {
  id          String       @id @default(uuid())
  size        String       @unique
  productions Production[]
  dispatches  Dispatch[]
  stock       Int          @default(0)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("brick_types")
}

model Worker {
  id                String             @id @default(uuid())
  name              String
  role              String
  paymentType       String
  rate              Float
  isActive          Boolean            @default(true)
  advanceBalance    Float              @default(0)
  productionWorkers ProductionWorker[]
  attendance        Attendance[]
  advances          WorkerAdvance[]
  wages             DailyWage[]
  expenses          Expense[]
  settlements       WeeklySettlement[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@map("workers")
}

model Production {
  id                String             @id @default(uuid())
  date              DateTime
  machineId         String
  machine           Machine            @relation(fields: [machineId], references: [id])
  shift             String
  brickTypeId       String
  brickType         BrickType          @relation(fields: [brickTypeId], references: [id])
  quantity          Int
  notes             String?
  workers           ProductionWorker[] @relation(name: "ProductionToWorkers")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@map("productions")
}

model ProductionWorker {
  id           String     @id @default(uuid())
  productionId String
  production   Production @relation(name: "ProductionToWorkers", fields: [productionId], references: [id])
  workerId     String
  worker       Worker     @relation(fields: [workerId], references: [id])
  quantity     Int
  createdAt    DateTime   @default(now())

  @@map("production_workers")
}

model Customer {
  id         String     @id @default(uuid())
  name       String
  phone      String?
  address    String?
  dispatches Dispatch[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@map("customers")
}

model Dispatch {
  id            String    @id @default(uuid())
  date          DateTime
  customerId    String
  customer      Customer  @relation(fields: [customerId], references: [id])
  brickTypeId   String
  brickType     BrickType @relation(fields: [brickTypeId], references: [id])
  quantity      Int
  distanceKm    Float?
  vehicleType   String
  transportCost Float
  loadingCost   Float
  paymentStatus String
  totalAmount   Float
  paidAmount    Float
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("dispatches")
}

model Expense {
  id          String          @id @default(uuid())
  date        DateTime
  category    String
  amount      Float
  notes       String?
  paymentMode String
  workerId    String?
  worker      Worker?         @relation(fields: [workerId], references: [id])
  materialId  String?
  material    RawMaterial?    @relation(fields: [materialId], references: [id])
  materials   MaterialUsage[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("expenses")
}

model CashEntry {
  id          String   @id @default(uuid())
  date        DateTime
  type        String
  amount      Float
  description String
  category    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("cash_entries")
}

model RawMaterial {
  id          String          @id @default(uuid())
  name        String          @unique
  unit        String
  description String?
  stock       Float           @default(0)
  isActive    Boolean         @default(true)
  usages      MaterialUsage[]
  expenses    Expense[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("raw_materials")
}

model MaterialUsage {
  id           String      @id @default(uuid())
  materialId   String
  material     RawMaterial @relation(fields: [materialId], references: [id])
  quantity     Float
  pricePerUnit Float       @default(0)
  totalCost    Float       @default(0)
  date         DateTime
  expenseId    String?
  expense      Expense?    @relation(fields: [expenseId], references: [id])
  createdAt    DateTime    @default(now())

  @@map("material_usages")
}

model Attendance {
  id       String   @id @default(uuid())
  workerId String
  worker   Worker   @relation(fields: [workerId], references: [id])
  date     DateTime
  present  Boolean  @default(true)

  @@unique([workerId, date])
  @@map("attendance")
}

model WorkerAdvance {
  id       String   @id @default(uuid())
  workerId String
  worker   Worker   @relation(fields: [workerId], references: [id])
  amount   Float
  type     String // GIVEN, ADJUSTED
  date     DateTime
  note     String?

  @@map("worker_advances")
}

model DailyWage {
  id          String   @id @default(uuid())
  workerId    String
  worker      Worker   @relation(fields: [workerId], references: [id])
  date        DateTime
  bricksMade  Int?
  wageAmount  Float
  advanceUsed Float    @default(0)
  netPayable  Float
  isPaid      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@map("daily_wages")
}

model WeeklySettlement {
  id            String   @id @default(uuid())
  workerId      String
  worker        Worker   @relation(fields: [workerId], references: [id])
  startDate     DateTime
  endDate       DateTime
  totalAmount   Float
  paymentStatus String
  generatedAt   DateTime @default(now())
  notes         String?

  @@map("weekly_settlements")
}
